{
  "name": "task-assignment-api",
  "version": "1.0.0",
  "description": "Task Assignment API with Audit Trail — Node.js/Express backend for internal task tracking with JWT auth, RBAC, and audit history.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --verbose --forceExit --detectOpenHandles",
    "test:coverage": "jest --verbose --forceExit --detectOpenHandles --coverage",
    "migrate": "node src/config/migrate.js"
  },
  "keywords": [
    "task",
    "api",
    "audit-trail",
    "express",
    "jwt",
    "rbac"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "helmet": "^7.1.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.21.0",
    "pg-hstore": "^2.3.4",
    "redis": "^6.0.0",
    "sequelize": "^6.37.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "sqlite3": "^5.1.7",
    "supertest": "^7.0.0"
  }
